  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "packages": {},
        "requests": {},
        "exec": [
          "if (pm.request.method === \"GET\" || pm.request.method === \"DELETE\") {\r",
          "    return;\r",
          "}\r",
          "\r",
          "if (!pm.request.url.getPath().includes(\"patients\")) {\r",
          "    return;\r",
          "}\r",
          "\r",
          "const randomNumber = Math.floor(Math.random() * 999) + 1;\r",
          "\r",
          "const withZeros = String(randomNumber).padStart(3, '0');\r",
          "\r",
          "const clinicalId = `PAC-${withZeros}`;\r",
          "\r",
          "pm.variables.set(\"CLINICALID\", clinicalId);\r",
          "\r",
          "const requestBody = JSON.parse(pm.request.body.raw);\r",
          "\r",
          "let room;\r",
          "if (requestBody.status === \"CRITICAL\") {\r",
          "    room = `UCI-${withZeros}`;\r",
          "} else {\r",
          "    room = `RM-${withZeros}`;\r",
          "}\r",
          "\r",
          "pm.variables.set(\"ROOMCODE\", room); "
        ]
      }
    },
